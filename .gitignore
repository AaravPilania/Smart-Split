# Large media files (Cloudflare Pages has a 25 MiB per-file limit)
*.mp4
*.webm
*.mov
*.avi
*.mkv

# Environment variables
.env
backend/.env

# Dependencies
node_modules

# Build output
dist
build

# Backup / generated files
*.bak
*.backup
*.local

# Capacitor native build artifacts (keep source, ignore generated build dirs)
android/.gradle/
android/build/
android/app/build/
android/local.properties
ios/App/Pods/
ios/App/build/
ios/.DS_Store

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

dist-ssr

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Markdown docs — only keep root README.md and backend/README.md
*.md
!README.md
!backend/README.md
