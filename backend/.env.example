# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/splitwise?retryWrites=true&w=majority

# JWT Secret (use a strong random secret in production)
JWT_SECRET=your_strong_jwt_secret_here

# Google OAuth Client ID (from Google Cloud Console → OAuth 2.0 credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Server Port (Render default is 10000; Railway injects PORT automatically)
PORT=10000

# CORS Origins (comma-separated) — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
